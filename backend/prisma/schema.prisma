generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  currency  String
  createdAt DateTime @default(now())

  users          User[]
  expenses       Expense[]
  approvalConfig ApprovalConfig?

  @@map("companies")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String
  companyId String
  managerId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses         Expense[]
  approvalTasks    ApprovalTask[] @relation("approver")
  approvalSteps    ApprovalStep[] @relation("approval_step_approver")

  @@index([companyId])
  @@index([managerId])
  @@index([companyId, role])
  @@map("users")
}

model Expense {
  id                String   @id @default(uuid())
  companyId         String
  employeeId        String
  submittedAmount   Float
  submittedCurrency String
  convertedAmount   Float
  companyCurrency   String
  category          String?
  description       String
  date              DateTime
  receiptUrl        String?
  status            String   @default("pending_approval")
  currentStep       Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee       User            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvalTasks  ApprovalTask[]

  @@index([companyId])
  @@index([employeeId])
  @@index([companyId, employeeId])
  @@index([companyId, status])
  @@map("expenses")
}

model ApprovalTask {
  id        String    @id @default(uuid())
  expenseId String
  approverId String
  step      Int       @default(1)
  status    String    @default("pending")
  comment   String?
  actedAt   DateTime?
  createdAt DateTime  @default(now())

  expense   Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  approver  User      @relation(fields: [approverId], references: [id], onDelete: Cascade, name: "approver")

  @@index([expenseId])
  @@index([approverId])
  @@index([expenseId, step])
  @@index([approverId, status])
  @@map("approval_tasks")
}

model ApprovalConfig {
  id        String   @id @default(uuid())
  companyId String   @unique
  createdAt DateTime @default(now())

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  steps   ApprovalStep[]

  @@index([companyId])
  @@map("approval_configs")
}

model ApprovalStep {
  id         String @id @default(uuid())
  configId   String
  stepOrder  Int
  approverId String

  config   ApprovalConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  approver User           @relation("approval_step_approver", fields: [approverId], references: [id], onDelete: Cascade)

  @@unique([configId, stepOrder])
  @@index([configId])
  @@index([approverId])
  @@map("approval_steps")
}
