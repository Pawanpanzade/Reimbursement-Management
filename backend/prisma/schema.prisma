generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  currency  String
  createdAt DateTime @default(now())

  users    User[]
  expenses Expense[]

  @@map("companies")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String
  companyId String
  managerId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([companyId])
  @@index([managerId])
  @@index([companyId, role])
  @@map("users")
}

model Expense {
  id                String   @id @default(uuid())
  companyId         String
  employeeId        String
  submittedAmount   Float
  submittedCurrency String
  convertedAmount   Float
  companyCurrency   String
  category          String?
  description       String
  date              DateTime
  receiptUrl        String?
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee User    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
  @@index([companyId, employeeId])
  @@index([companyId, status])
  @@map("expenses")
}
